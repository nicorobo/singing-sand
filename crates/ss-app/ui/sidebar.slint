import { LineEdit, ScrollView } from "std-widgets.slint";
import { SidebarEntry, DirTreeItem, SidebarTagItem, SidebarTagRow, TagColorOption } from "types.slint";

export component Sidebar inherits Rectangle {
    width: 200px;
    background: #11111b;

    in property <[DirTreeItem]>   dir-tree-items;
    in property <[SidebarEntry]>  sidebar-playlists;
    in property <[SidebarTagRow]> sidebar-tag-rows;
    in property <[TagColorOption]> tag-color-palette;

    // Drag state — read from parent, written to parent
    in property <int>    drag-track-id;
    in property <length> drag-x;
    in property <length> drag-y;

    // Shared navigation + UI state (two-way bound to AppWindow)
    in-out property <int>    nav-kind;
    in-out property <int>    nav-id;
    in-out property <string> nav-dir;
    in-out property <bool>   creating-playlist;
    in-out property <bool>   creating-tag;
    in-out property <int>    drag-over-playlist-id;

    callback nav-all();
    callback nav-select-dir(string);
    callback nav-playlist(int);
    callback nav-tag(int);
    callback add-directory-clicked();
    callback toggle-dir-expanded(string);
    callback remove-scanned-dir(string);
    callback create-playlist(string);
    callback create-tag(string, string);   // name, color hex
    callback delete-tag(int);
    callback update-tag(int, string, string);   // id, name, color hex
    callback settings-clicked();

    // Tag creation/edit state
    in-out property <string> creating-tag-color: "#89b4fa";
    in-out property <color>  creating-tag-color-value: #89b4fa;  // mirror for display
    in-out property <bool>   color-picker-open: false;
    in-out property <bool>   editing-tag: false;
    in-out property <int>    editing-tag-id: -1;
    in-out property <string> editing-tag-name: "";

    VerticalLayout {
        sidebar-scroll := ScrollView {
            vertical-stretch: 1;
            viewport-width: 200px;

            VerticalLayout {
                width: 200px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 0px;

                // All Tracks row
                Rectangle {
                    height: 32px;
                    background: root.nav-kind == 0
                        ? #313244
                        : (all-ta.has-hover ? #1e1e2e : transparent);

                    HorizontalLayout {
                        padding-left: 12px;
                        spacing: 6px;
                        Text {
                            text: "All Tracks";
                            color: root.nav-kind == 0 ? #cdd6f4 : #a6adc8;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }

                    all-ta := TouchArea {
                        clicked => {
                            root.nav-kind = 0;
                            root.nav-id = -1;
                            root.nav-dir = "";
                            root.nav-all();
                        }
                    }
                }

                // ── Directories section ───────────────────────────────────
                Rectangle {
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        padding-top: 10px;
                        Text {
                            text: "DIRECTORIES";
                            color: #45475a;
                            font-size: 10px;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 18px;
                            height: 18px;
                            y: 5px;
                            border-radius: 3px;
                            background: add-dir-ta.has-hover ? #313244 : transparent;
                            Text {
                                text: "+";
                                color: #6c7086;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 14px;
                            }
                            add-dir-ta := TouchArea {
                                clicked => { root.add-directory-clicked(); }
                            }
                        }
                    }
                }

                // Directory tree — flat list with per-item indent + chevron
                for item in root.dir-tree-items: Rectangle {
                    height: 32px;
                    property <bool> selected: root.nav-kind == 1 && root.nav-dir == item.path;
                    background: selected ? #313244 : (row-ta.has-hover ? #1e1e2e : transparent);

                    HorizontalLayout {
                        spacing: 0;
                        Rectangle { width: item.indent * 12px + 4px; }
                        Rectangle {
                            width: 16px;
                            Text {
                                text: item.has-children ? (item.is-expanded ? "▼" : "▶") : "";
                                color: #6c7086;
                                font-size: 9px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: item.name;
                            color: selected ? #cdd6f4 : #a6adc8;
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                            wrap: no-wrap;
                            horizontal-stretch: 1;
                        }
                        if item.is-root: Rectangle {
                            width: 22px;
                            visible: row-ta.has-hover;
                            background: remove-dir-ta.has-hover ? #f38ba820 : transparent;
                            border-radius: 9px;
                            Text {
                                text: "×";
                                color: #f38ba8;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            remove-dir-ta := TouchArea {
                                clicked => { root.remove-scanned-dir(item.path); }
                            }
                        }
                        Rectangle { width: 4px; }
                    }

                    row-ta := TouchArea {
                        clicked => {
                            root.nav-kind = 1;
                            root.nav-id = -1;
                            root.nav-dir = item.path;
                            root.nav-select-dir(item.path);
                            if (item.has-children) {
                                root.toggle-dir-expanded(item.path);
                            }
                        }
                    }
                }

                // ── Playlists section ─────────────────────────────────────
                Rectangle {
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        padding-top: 10px;
                        Text {
                            text: "PLAYLISTS";
                            color: #45475a;
                            font-size: 10px;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 18px;
                            height: 18px;
                            y: 5px;
                            border-radius: 3px;
                            background: add-pl-ta.has-hover ? #313244 : transparent;
                            Text {
                                text: "+";
                                color: #6c7086;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 14px;
                            }
                            add-pl-ta := TouchArea {
                                clicked => { root.creating-playlist = true; }
                            }
                        }
                    }
                }

                // Sidebar layout geometry (px from VerticalLayout top):
                //   8 padding-top + 32 All-Tracks + 28 DIRS header
                //   + N*32 dir tree rows + 28 PLAYLISTS header = 96 + N*32
                // Each playlist row adds another 32px.
                // sidebar-scroll.viewport-y accounts for scroll offset (0 = top, negative = scrolled down).
                for pl[pl-i] in root.sidebar-playlists: Rectangle {
                    height: 32px;

                    property <length> item-top:
                        96px + root.dir-tree-items.length * 32px + pl-i * 32px
                        + sidebar-scroll.viewport-y;

                    property <bool> is-drop-target:
                        root.drag-track-id >= 0
                        && root.drag-x < 200px
                        && root.drag-y >= item-top
                        && root.drag-y < item-top + 32px;

                    changed is-drop-target => {
                        if root.drag-track-id >= 0
                                && root.drag-x < 200px
                                && root.drag-y >= item-top
                                && root.drag-y < item-top + 32px {
                            root.drag-over-playlist-id = pl.id;
                        } else if root.drag-over-playlist-id == pl.id {
                            root.drag-over-playlist-id = -1;
                        }
                    }

                    background: self.is-drop-target
                        ? #2a3a5e
                        : (root.nav-kind == 2 && root.nav-id == pl.id
                            ? #313244
                            : (pl-ta.has-hover ? #1e1e2e : transparent));
                    border-width: 1px;
                    border-color: self.is-drop-target ? #89b4fa : transparent;

                    HorizontalLayout {
                        padding-left: 20px;
                        Text {
                            text: pl.label;
                            color: (root.drag-track-id >= 0 && root.drag-over-playlist-id == pl.id)
                                ? #89b4fa
                                : (root.nav-kind == 2 && root.nav-id == pl.id
                                    ? #cdd6f4 : #a6adc8);
                            font-size: 12px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    pl-ta := TouchArea {
                        clicked => {
                            root.nav-kind = 2;
                            root.nav-id = pl.id;
                            root.nav-dir = "";
                            root.nav-playlist(pl.id);
                        }
                    }
                }

                if root.creating-playlist: Rectangle {
                    height: 32px;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 8px;
                        padding-top: 4px;
                        padding-bottom: 4px;
                        new-pl-input := LineEdit {
                            placeholder-text: "Playlist name…";
                            font-size: 12px;
                            horizontal-stretch: 1;
                            accepted(text) => {
                                if text != "" {
                                    root.create-playlist(text);
                                }
                                root.creating-playlist = false;
                                self.text = "";
                            }
                        }
                    }
                }

                // ── Tags section ──────────────────────────────────────────
                Rectangle {
                    height: 28px;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 8px;
                        padding-top: 10px;
                        Text {
                            text: "TAGS";
                            color: #45475a;
                            font-size: 10px;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Rectangle {
                            width: 18px;
                            height: 18px;
                            y: 5px;
                            border-radius: 3px;
                            background: add-tag-ta.has-hover ? #313244 : transparent;
                            Text {
                                text: "+";
                                color: #6c7086;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 14px;
                            }
                            add-tag-ta := TouchArea {
                                clicked => {
                                    root.editing-tag = false;
                                    root.editing-tag-id = -1;
                                    root.editing-tag-name = "";
                                    root.creating-tag-color = "#89b4fa";
                                    root.creating-tag-color-value = #89b4fa;
                                    root.creating-tag = true;
                                }
                            }
                        }
                    }
                }

                // Tag pills — one HorizontalLayout per row (rows pre-computed in Rust)
                for row in root.sidebar-tag-rows: HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 8px;
                    padding-top: 3px;
                    padding-bottom: 3px;
                    spacing: 6px;
                    alignment: start;

                    for tag in row.items: tag-ctx-menu := ContextMenuArea {
                        width: pill-text.preferred-width + 20px;
                        height: 22px;

                        Menu {
                            MenuItem {
                                title: "Edit";
                                activated => {
                                    root.editing-tag = true;
                                    root.editing-tag-id = tag.id;
                                    root.editing-tag-name = tag.name;
                                    root.creating-tag-color = tag.color-hex;
                                    root.creating-tag-color-value = tag.color;
                                    root.creating-tag = true;
                                    root.color-picker-open = false;
                                }
                            }
                            MenuItem {
                                title: "Delete";
                                activated => { root.delete-tag(tag.id); }
                            }
                        }

                        pill-rect := Rectangle {
                            property <bool> active: root.nav-kind == 3 && root.nav-id == tag.id;
                            width: parent.width;
                            height: 22px;
                            border-radius: 11px;
                            background: active ? tag.color.darker(0.2)
                                               : (tag-pill-ta.has-hover ? tag.color.brighter(0.05) : tag.color);

                            pill-text := Text {
                                x: (parent.width - self.preferred-width) / 2;
                                y: (parent.height - self.preferred-height) / 2;
                                text: tag.name;
                                color: tag.text-dark ? #1e1e2e : #cdd6f4;
                                font-size: 11px;
                            }

                            tag-pill-ta := TouchArea {
                                clicked => {
                                    root.nav-kind = 3;
                                    root.nav-id = tag.id;
                                    root.nav-dir = "";
                                    root.color-picker-open = false;
                                    root.nav-tag(tag.id);
                                }
                                pointer-event(e) => {
                                    if e.button == PointerEventButton.right && e.kind == PointerEventKind.down {
                                        tag-ctx-menu.show({x: self.mouse-x, y: self.mouse-y});
                                    }
                                }
                            }
                        }
                    }
                }

                // Tag creation / edit form
                if root.creating-tag: VerticalLayout {
                    spacing: 0px;
                    init => {
                        if root.editing-tag {
                            new-tag-input.text = root.editing-tag-name;
                        }
                    }

                    // Row 1: name input
                    Rectangle {
                        height: 32px;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 8px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            new-tag-input := LineEdit {
                                placeholder-text: "Tag name…";
                                font-size: 12px;
                                horizontal-stretch: 1;
                                accepted(text) => {
                                    if text != "" {
                                        if root.editing-tag {
                                            root.update-tag(root.editing-tag-id, text, root.creating-tag-color);
                                        } else {
                                            root.create-tag(text, root.creating-tag-color);
                                        }
                                    }
                                    root.creating-tag = false;
                                    root.editing-tag = false;
                                    root.editing-tag-id = -1;
                                    root.editing-tag-name = "";
                                    root.color-picker-open = false;
                                    root.creating-tag-color = "#89b4fa";
                                    root.creating-tag-color-value = #89b4fa;
                                    self.text = "";
                                }
                            }
                        }
                    }

                    // Row 2: selected color circle (click to open palette)
                    Rectangle {
                        height: 28px;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            spacing: 6px;
                            alignment: start;

                            // Shows the currently selected color; click to toggle palette
                            color-swatch := Rectangle {
                                width: 18px;
                                height: 18px;
                                border-radius: 9px;
                                border-width: 2px;
                                border-color: color-swatch-ta.has-hover ? #cdd6f4 : #45475a;
                                background: root.creating-tag-color-value;

                                color-swatch-ta := TouchArea {
                                    clicked => {
                                        root.color-picker-open = !root.color-picker-open;
                                    }
                                }
                            }

                            Text {
                                text: root.color-picker-open ? "Pick a color:" : "Color";
                                color: #6c7086;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Row 3: color palette (shown when color-picker-open)
                    if root.color-picker-open: Rectangle {
                        height: 32px;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 8px;
                            padding-top: 6px;
                            padding-bottom: 6px;
                            spacing: 6px;
                            alignment: start;

                            for c in root.tag-color-palette: Rectangle {
                                property <bool> selected: root.creating-tag-color == c.hex;
                                width: 20px;
                                height: 20px;
                                border-radius: 10px;
                                background: c.color;
                                border-width: selected ? 2px : 0px;
                                border-color: #cdd6f4;

                                TouchArea {
                                    clicked => {
                                        root.creating-tag-color = c.hex;
                                        root.creating-tag-color-value = c.color;
                                        root.color-picker-open = false;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        } // ScrollView

        // ── Gear icon footer ──────────────────────────────────────────
        Rectangle {
            height: 36px;
            background: #0d0d17;
            HorizontalLayout {
                padding-left: 12px;
                alignment: start;
                Text {
                    text: "⚙";
                    color: gear-ta.has-hover ? #cdd6f4 : #6c7086;
                    font-size: 14px;
                    vertical-alignment: center;
                }
            }
            gear-ta := TouchArea {
                clicked => { root.settings-clicked(); }
            }
        }
    } // VerticalLayout
}
