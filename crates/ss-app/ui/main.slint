import { SettingsWindow } from "settings.slint";
import { Sidebar } from "sidebar.slint";
import { TrackList } from "track-list.slint";
import { PlayerPanel } from "player-panel.slint";
import { TrackItem, SidebarEntry, TagItem, ExpandedTagItem, ExpandedPlaylistItem, DirTreeItem } from "types.slint";

export { SettingsWindow }
export { TrackItem, SidebarEntry, TagItem, ExpandedTagItem, ExpandedPlaylistItem, DirTreeItem } from "types.slint";

export component AppWindow inherits Window {
    title: "Singing Sand";
    preferred-width: 1000px;
    preferred-height: 600px;
    background: #1e1e2e;

    // Track list
    in property <[TrackItem]> tracks;
    in-out property <int>  current-track-id: -1;
    in-out property <bool> is-playing: false;
    in property <float>    position: 0.0;
    in property <float>    duration: 0.0;
    in property <image>    waveform-image;

    // Now-playing panel
    in property <image>  now-playing-art;
    in property <string> now-playing-title;
    in property <string> now-playing-artist;
    in-out property <int> pending-analysis-count: 0;

    // Sidebar data
    in property <[DirTreeItem]>   dir-tree-items;
    in property <[SidebarEntry]>  sidebar-playlists;
    in property <[SidebarEntry]>  sidebar-tags;

    // Directory management
    in-out property <bool>   show-dir-duplicate-dialog: false;
    in-out property <string> dir-duplicate-message: "";

    // Navigation state
    in-out property <int>    nav-kind: 0;       // 0=all, 1=dir, 2=playlist, 3=tag
    in-out property <int>    nav-id: -1;
    in-out property <string> nav-dir: "";

    // Tag chips for the currently selected track
    in property <[TagItem]> current-track-tags;

    // Inline creation state
    in-out property <bool> creating-playlist: false;
    in-out property <bool> creating-tag: false;

    // Drag-and-drop state
    in-out property <int>    drag-track-id: -1;
    in-out property <string> drag-title: "";
    in-out property <length> drag-x: 0;
    in-out property <length> drag-y: 0;
    in-out property <int>    drag-over-playlist-id: -1;
    in-out property <bool>   drag-is-multi: false;
    in-out property <int>    drag-count: 0;

    // Transport callbacks
    callback play-track(int);
    callback play();
    callback pause();
    callback stop();
    callback seek(float);
    callback next-track();
    callback prev-track();

    // Navigation callbacks — Rust reacts by reloading track list
    callback nav-all();
    callback nav-select-dir(string);
    callback nav-playlist(int);
    callback nav-tag(int);

    // Directory management callbacks
    callback add-directory-clicked();
    callback toggle-dir-expanded(string);
    callback remove-scanned-dir(string);

    // Sidebar management
    callback create-playlist(string);
    callback create-tag(string);

    // Tag assignment for current track
    callback toggle-tag(int, bool);

    // Expanded track row
    in-out property <int>  expanded-track-id: -1;
    in property <[ExpandedTagItem]>      expanded-track-tags;
    in property <[ExpandedPlaylistItem]> expanded-track-playlists;
    in property <string>                 expanded-track-notes;
    in property <string>                 expanded-track-duration-formatted;

    callback expand-track(int);
    callback remove-tag-from-expanded(int);
    callback save-notes(int, string);

    // Playlist track management
    callback add-to-playlist(int, int);
    callback remove-from-playlist(int, int);

    // Multiselect
    callback track-clicked(int, bool, bool);
    callback add-selected-to-playlist(int);

    // Settings window — opened from Rust via on_settings_clicked
    callback settings-clicked();

    // Search / filter
    in-out property <string> search-filter: "";
    callback search-filter-changed(string);
    callback clear-search-filter();

    HorizontalLayout {
        // ── Sidebar ──────────────────────────────────────────────────────────
        Sidebar {
            dir-tree-items:    root.dir-tree-items;
            sidebar-playlists: root.sidebar-playlists;
            sidebar-tags:      root.sidebar-tags;
            drag-track-id:     root.drag-track-id;
            drag-x:            root.drag-x;
            drag-y:            root.drag-y;

            nav-kind             <=> root.nav-kind;
            nav-id               <=> root.nav-id;
            nav-dir              <=> root.nav-dir;
            creating-playlist    <=> root.creating-playlist;
            creating-tag         <=> root.creating-tag;
            drag-over-playlist-id <=> root.drag-over-playlist-id;

            nav-all             => { root.clear-search-filter(); root.nav-all(); }
            nav-select-dir(p)   => { root.clear-search-filter(); root.nav-select-dir(p); }
            nav-playlist(id)    => { root.clear-search-filter(); root.nav-playlist(id); }
            nav-tag(id)         => { root.clear-search-filter(); root.nav-tag(id); }
            add-directory-clicked => { root.add-directory-clicked(); }
            toggle-dir-expanded(p) => { root.toggle-dir-expanded(p); }
            remove-scanned-dir(p)  => { root.remove-scanned-dir(p); }
            create-playlist(n)  => { root.create-playlist(n); }
            create-tag(n)       => { root.create-tag(n); }
            settings-clicked    => { root.settings-clicked(); }
        }

        // Sidebar divider
        Rectangle {
            width: 1px;
            background: #313244;
        }

        // ── Main content ──────────────────────────────────────────────────────
        VerticalLayout {
            horizontal-stretch: 1;

            TrackList {
                tracks:                          root.tracks;
                current-track-tags:              root.current-track-tags;
                expanded-track-tags:             root.expanded-track-tags;
                expanded-track-playlists:        root.expanded-track-playlists;
                expanded-track-notes:            root.expanded-track-notes;
                expanded-track-duration-formatted: root.expanded-track-duration-formatted;

                current-track-id      <=> root.current-track-id;
                is-playing            <=> root.is-playing;
                expanded-track-id     <=> root.expanded-track-id;
                drag-track-id         <=> root.drag-track-id;
                drag-title            <=> root.drag-title;
                drag-x                <=> root.drag-x;
                drag-y                <=> root.drag-y;
                drag-over-playlist-id <=> root.drag-over-playlist-id;
                drag-is-multi         <=> root.drag-is-multi;
                drag-count            <=> root.drag-count;
                nav-kind              <=> root.nav-kind;
                nav-id                <=> root.nav-id;
                nav-dir               <=> root.nav-dir;

                play-track(id)            => { root.play-track(id); }
                expand-track(id)          => { root.expand-track(id); }
                remove-tag-from-expanded(id) => { root.remove-tag-from-expanded(id); }
                save-notes(id, text)      => { root.save-notes(id, text); }
                toggle-tag(id, v)         => { root.toggle-tag(id, v); }
                add-to-playlist(pl, tr)   => { root.add-to-playlist(pl, tr); }
                remove-from-playlist(pl, tr) => { root.remove-from-playlist(pl, tr); }
                nav-tag(id)               => { root.nav-tag(id); }
                nav-playlist(id)          => { root.nav-playlist(id); }
                track-clicked(id, sh, me) => { root.track-clicked(id, sh, me); }
                add-selected-to-playlist(pl) => { root.add-selected-to-playlist(pl); }

                search-filter             <=> root.search-filter;
                search-filter-changed(s)  => { root.search-filter-changed(s); }
                clear-search-filter       => { root.clear-search-filter(); }
            }

            PlayerPanel {
                waveform-image:    root.waveform-image;
                position:          root.position;
                duration:          root.duration;
                now-playing-art:   root.now-playing-art;
                now-playing-title: root.now-playing-title;
                now-playing-artist: root.now-playing-artist;
                current-track-id:  root.current-track-id;
                nav-kind:          root.nav-kind;
                nav-id:            root.nav-id;

                is-playing <=> root.is-playing;

                seek(f)           => { root.seek(f); }
                play              => { root.play(); }
                pause             => { root.pause(); }
                prev-track        => { root.prev-track(); }
                next-track        => { root.next-track(); }
                add-to-playlist(pl, tr) => { root.add-to-playlist(pl, tr); }
            }
        }
    }

    // Analysis counter — bottom-right overlay while background analysis is running
    if root.pending-analysis-count > 0: Text {
        x: root.width - self.preferred-width - 12px;
        y: root.height - self.preferred-height - 8px;
        text: "Analyzing " + root.pending-analysis-count + " tracks…";
        color: #585b70;
        font-size: 11px;
    }

    // Duplicate-directory warning dialog
    if root.show-dir-duplicate-dialog: Rectangle {
        background: #00000099;
        Rectangle {
            width: 280px;
            height: 110px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #1e1e2e;
            border-radius: 8px;
            border-width: 1px;
            border-color: #313244;
            drop-shadow-color: #00000066;
            drop-shadow-blur: 12px;
            drop-shadow-offset-y: 4px;

            VerticalLayout {
                padding: 20px;
                spacing: 14px;
                Text {
                    text: root.dir-duplicate-message;
                    color: #cdd6f4;
                    font-size: 12px;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }
                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: ok-ta.has-hover ? #45475a : #313244;
                    Text {
                        text: "OK";
                        color: #cdd6f4;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    ok-ta := TouchArea {
                        clicked => {
                            root.show-dir-duplicate-dialog = false;
                            root.dir-duplicate-message = "";
                        }
                    }
                }
            }
        }
        // Block all input behind the dialog
        TouchArea { }
    }

    // Drag ghost — floats above everything while dragging
    if root.drag-track-id >= 0: Rectangle {
        x: root.drag-x + 12px;
        y: root.drag-y - 12px;
        width: 180px;
        height: 24px;
        border-radius: 4px;
        background: #313244;
        border-width: 1px;
        border-color: #89b4fa;
        drop-shadow-color: #00000066;
        drop-shadow-blur: 6px;
        drop-shadow-offset-y: 2px;

        Text {
            x: 8px;
            text: root.drag-title;
            color: #cdd6f4;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
            width: parent.width - 16px;
        }
    }
}
