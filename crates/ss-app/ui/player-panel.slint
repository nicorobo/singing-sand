import { Button } from "std-widgets.slint";

// Small plain-text button used in the now-playing transport row.
component TransportButton inherits Rectangle {
    in property <string> label;
    callback clicked;

    height: 24px;
    border-radius: 4px;
    background: ta.has-hover ? #313244 : transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        alignment: center;

        Text {
            text: root.label;
            color: #cdd6f4;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Waveform + now-playing panel + "Add to playlist" button.
export component PlayerPanel inherits VerticalLayout {
    in property <image>  waveform-image;
    in property <float>  position: 0.0;
    in property <float>  duration: 0.0;
    in property <image>  now-playing-art;
    in property <string> now-playing-title;
    in property <string> now-playing-artist;
    in property <int>    current-track-id: -1;
    in property <int>    nav-kind;
    in property <int>    nav-id;

    in-out property <bool> is-playing: false;

    callback seek(float);
    callback play();
    callback pause();
    callback prev-track();
    callback next-track();
    callback add-to-playlist(int, int);

    // Waveform display
    waveform-rect := Rectangle {
        height: 48px;
        background: #181825;

        Image {
            width: parent.width;
            height: parent.height;
            source: root.waveform-image;
            image-fit: fill;
        }

        if root.waveform-image.width == 0: Text {
            text: "No track loaded";
            color: #45475a;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }

        if root.duration > 0.0 && root.waveform-image.width > 0: Rectangle {
            x: (root.position / root.duration) * waveform-rect.width - 1px;
            y: 0;
            width: 2px;
            height: parent.height;
            background: #f38ba8;
        }

        waveform-ta := TouchArea {
            clicked => {
                if root.duration > 0.0 {
                    root.seek(waveform-ta.mouse-x / waveform-rect.width);
                }
            }
        }
    }

    // Now-playing panel (visible when a track is loaded)
    if root.current-track-id >= 0: Rectangle {
        height: 80px;
        background: #181825;

        // Top divider
        Rectangle {
            y: 0;
            height: 1px;
            width: parent.width;
            background: #313244;
        }

        HorizontalLayout {
            padding: 10px;
            spacing: 12px;

            // Album art
            Rectangle {
                width: 60px;
                height: 60px;
                background: #313244;
                border-radius: 4px;

                Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.now-playing-art;
                    image-fit: cover;
                    visible: root.now-playing-art.width > 0;
                }

                Text {
                    text: "♪";
                    color: #45475a;
                    font-size: 24px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    visible: root.now-playing-art.width == 0;
                }
            }

            // Track info + controls
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                spacing: 4px;

                Text {
                    text: root.now-playing-title != "" ? root.now-playing-title : "(unknown)";
                    font-size: 13px;
                    font-weight: 700;
                    color: #cdd6f4;
                    overflow: elide;
                    wrap: no-wrap;
                }

                Text {
                    text: root.now-playing-artist;
                    font-size: 11px;
                    color: #a6adc8;
                    overflow: elide;
                    wrap: no-wrap;
                }

                HorizontalLayout {
                    spacing: 4px;
                    alignment: start;

                    TransportButton {
                        label: "Prev";
                        clicked => { root.prev-track(); }
                    }

                    TransportButton {
                        label: root.is-playing ? "Pause" : "Play";
                        clicked => {
                            if root.is-playing {
                                root.is-playing = false;
                                root.pause();
                            } else {
                                root.is-playing = true;
                                root.play();
                            }
                        }
                    }

                    TransportButton {
                        label: "Next";
                        clicked => { root.next-track(); }
                    }
                }
            }
        }
    }

    // Shown only when browsing a playlist — adds current track
    if root.nav-kind == 2 && root.current-track-id >= 0: Rectangle {
        height: 52px;
        background: #181825;

        HorizontalLayout {
            alignment: center;
            padding: 10px;

            Button {
                text: "Add to playlist";
                clicked => { root.add-to-playlist(root.nav-id, root.current-track-id); }
            }
        }
    }
}
