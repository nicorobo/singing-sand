import { Slider, ComboBox } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    title: "Waveform Settings";
    background: #1e1e2e;
    preferred-width: 320px;
    preferred-height: 620px;

    // in-out properties (initialized from Rust on open)
    in-out property <float> amplitude-scale:  1.0;
    in-out property <float> low-gain:         1.0;
    in-out property <float> mid-gain:         1.0;
    in-out property <float> high-gain:        1.0;
    in-out property <int>   display-style:    0;   // 0=Mirrored, 1=TopHalf
    in-out property <int>   color-scheme:     0;   // 0..3
    in-out property <int>   normalize-mode:   0;   // 0=None, 1=PerBand, 2=Global
    in-out property <float> gamma:            0.6;
    in-out property <float> noise-floor:      0.0;
    in-out property <float> smoothing:        1.0; // 1–8, rounded to int

    // Preview waveform image (rendered by Rust, pushed on every settings change)
    in property <image> preview-waveform;

    // Callbacks: xxx-changed fires on every change (render path)
    //            xxx-released fires on mouse-up (DB-save path, sliders only)
    callback amplitude-scale-changed(float);
    callback amplitude-scale-released(float);
    callback low-gain-changed(float);
    callback low-gain-released(float);
    callback mid-gain-changed(float);
    callback mid-gain-released(float);
    callback high-gain-changed(float);
    callback high-gain-released(float);
    callback gamma-changed(float);
    callback gamma-released(float);
    callback noise-floor-changed(float);
    callback noise-floor-released(float);
    callback smoothing-changed(float);
    callback smoothing-released(float);
    callback display-style-changed(int);
    callback color-scheme-changed(int);
    callback normalize-mode-changed(int);

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // ── Header ────────────────────────────────────────────────────────────
        Text {
            text: "Waveform Settings";
            color: #cdd6f4;
            font-size: 14px;
            font-weight: 600;
        }

        // ── Preview waveform ──────────────────────────────────────────────────
        Image {
            source: root.preview-waveform;
            width: 100%;
            height: 60px;
            image-fit: fill;
        }

        // ── Amplitude scale ───────────────────────────────────────────────────
        Text {
            text: "AMPLITUDE SCALE";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Slider {
                horizontal-stretch: 1;
                minimum: 0.1;
                maximum: 4.0;
                value: root.amplitude-scale;
                changed(v) => {
                    root.amplitude-scale = v;
                    root.amplitude-scale-changed(v);
                }
                released(v) => {
                    root.amplitude-scale-released(v);
                }
            }
            Text {
                text: Math.round(root.amplitude-scale * 10) / 10 + "×";
                color: #a6adc8;
                font-size: 11px;
                vertical-alignment: center;
                width: 36px;
            }
        }

        // ── Per-band gain ─────────────────────────────────────────────────────
        Text {
            text: "PER-BAND GAIN";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Text { text: "Low"; color: #fab387; font-size: 11px; vertical-alignment: center; width: 32px; }
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 4.0;
                value: root.low-gain;
                changed(v) => {
                    root.low-gain = v;
                    root.low-gain-changed(v);
                }
                released(v) => {
                    root.low-gain-released(v);
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Text { text: "Mid"; color: #89b4fa; font-size: 11px; vertical-alignment: center; width: 32px; }
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 4.0;
                value: root.mid-gain;
                changed(v) => {
                    root.mid-gain = v;
                    root.mid-gain-changed(v);
                }
                released(v) => {
                    root.mid-gain-released(v);
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Text { text: "High"; color: #b4befe; font-size: 11px; vertical-alignment: center; width: 32px; }
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 4.0;
                value: root.high-gain;
                changed(v) => {
                    root.high-gain = v;
                    root.high-gain-changed(v);
                }
                released(v) => {
                    root.high-gain-released(v);
                }
            }
        }

        // ── Display style ─────────────────────────────────────────────────────
        Text {
            text: "DISPLAY STYLE";
            color: #45475a;
            font-size: 10px;
        }

        ComboBox {
            model: ["Mirrored", "Half"];
            current-index: root.display-style;
            selected(v) => {
                root.display-style = self.current-index;
                root.display-style-changed(self.current-index);
            }
        }

        // ── Color scheme ──────────────────────────────────────────────────────
        Text {
            text: "COLOR SCHEME";
            color: #45475a;
            font-size: 10px;
        }

        ComboBox {
            model: ["Peach / Blue / Lavender", "Monochrome", "Per-Band Solid", "Grayscale"];
            current-index: root.color-scheme;
            selected(v) => {
                root.color-scheme = self.current-index;
                root.color-scheme-changed(self.current-index);
            }
        }

        // ── Normalization ─────────────────────────────────────────────────────
        Text {
            text: "NORMALIZE";
            color: #45475a;
            font-size: 10px;
        }

        ComboBox {
            model: ["None", "Per Band", "Global"];
            current-index: root.normalize-mode;
            selected(v) => {
                root.normalize-mode = self.current-index;
                root.normalize-mode-changed(self.current-index);
            }
        }

        // ── Gamma ─────────────────────────────────────────────────────────────
        Text {
            text: "GAMMA";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Slider {
                horizontal-stretch: 1;
                minimum: 0.3;
                maximum: 1.5;
                value: root.gamma;
                changed(v) => {
                    root.gamma = v;
                    root.gamma-changed(v);
                }
                released(v) => {
                    root.gamma-released(v);
                }
            }
            Text {
                text: Math.round(root.gamma * 100) / 100 + "";
                color: #a6adc8;
                font-size: 11px;
                vertical-alignment: center;
                width: 36px;
            }
        }

        // ── Noise floor ───────────────────────────────────────────────────────
        Text {
            text: "NOISE FLOOR";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 0.2;
                value: root.noise-floor;
                changed(v) => {
                    root.noise-floor = v;
                    root.noise-floor-changed(v);
                }
                released(v) => {
                    root.noise-floor-released(v);
                }
            }
            Text {
                text: Math.round(root.noise-floor * 100) / 100 + "";
                color: #a6adc8;
                font-size: 11px;
                vertical-alignment: center;
                width: 36px;
            }
        }

        // ── Smoothing ─────────────────────────────────────────────────────────
        Text {
            text: "SMOOTHING";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Slider {
                horizontal-stretch: 1;
                minimum: 1.0;
                maximum: 8.0;
                value: root.smoothing;
                changed(v) => {
                    root.smoothing = v;
                    root.smoothing-changed(v);
                }
                released(v) => {
                    root.smoothing-released(v);
                }
            }
            Text {
                text: Math.round(root.smoothing) + "";
                color: #a6adc8;
                font-size: 11px;
                vertical-alignment: center;
                width: 36px;
            }
        }
    }
}
