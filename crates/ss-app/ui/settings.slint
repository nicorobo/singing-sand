import { CheckBox, Slider, ComboBox } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    title: "Waveform Settings";
    background: #1e1e2e;
    preferred-width: 320px;
    preferred-height: 460px;

    // in-out properties (initialized from Rust on open)
    in-out property <bool>  show-low:        true;
    in-out property <bool>  show-mid:        true;
    in-out property <bool>  show-high:       true;
    in-out property <float> amplitude-scale: 1.0;
    in-out property <float> low-gain:        1.0;
    in-out property <float> mid-gain:        1.0;
    in-out property <float> high-gain:       1.0;
    in-out property <int>   display-style:   0;   // 0=Mirrored, 1=TopHalf
    in-out property <int>   color-scheme:    0;   // 0..3
    in-out property <bool>  normalize:       false;

    // Callbacks fired immediately on change (no Apply button)
    callback show-low-changed(bool);
    callback show-mid-changed(bool);
    callback show-high-changed(bool);
    callback amplitude-scale-changed(float);
    callback low-gain-changed(float);
    callback mid-gain-changed(float);
    callback high-gain-changed(float);
    callback display-style-changed(int);
    callback color-scheme-changed(int);
    callback normalize-changed(bool);

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // ── Header ────────────────────────────────────────────────────────────
        Text {
            text: "Waveform Settings";
            color: #cdd6f4;
            font-size: 14px;
            font-weight: 600;
        }

        // ── Frequency bands ───────────────────────────────────────────────────
        Text {
            text: "FREQUENCY BANDS";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 16px;
            CheckBox {
                text: "Low";
                checked: root.show-low;
                toggled => {
                    root.show-low = self.checked;
                    root.show-low-changed(self.checked);
                }
            }
            CheckBox {
                text: "Mid";
                checked: root.show-mid;
                toggled => {
                    root.show-mid = self.checked;
                    root.show-mid-changed(self.checked);
                }
            }
            CheckBox {
                text: "High";
                checked: root.show-high;
                toggled => {
                    root.show-high = self.checked;
                    root.show-high-changed(self.checked);
                }
            }
        }

        // ── Amplitude scale ───────────────────────────────────────────────────
        Text {
            text: "AMPLITUDE SCALE";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Slider {
                horizontal-stretch: 1;
                minimum: 0.1;
                maximum: 4.0;
                value: root.amplitude-scale;
                released(v) => {
                    root.amplitude-scale = v;
                    root.amplitude-scale-changed(v);
                }
            }
            Text {
                text: Math.round(root.amplitude-scale * 10) / 10 + "×";
                color: #a6adc8;
                font-size: 11px;
                vertical-alignment: center;
                width: 36px;
            }
        }

        // ── Per-band gain ─────────────────────────────────────────────────────
        Text {
            text: "PER-BAND GAIN";
            color: #45475a;
            font-size: 10px;
        }

        HorizontalLayout {
            spacing: 8px;
            Text { text: "Low"; color: #fab387; font-size: 11px; vertical-alignment: center; width: 32px; }
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 4.0;
                value: root.low-gain;
                released(v) => {
                    root.low-gain = v;
                    root.low-gain-changed(v);
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Text { text: "Mid"; color: #89b4fa; font-size: 11px; vertical-alignment: center; width: 32px; }
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 4.0;
                value: root.mid-gain;
                released(v) => {
                    root.mid-gain = v;
                    root.mid-gain-changed(v);
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Text { text: "High"; color: #b4befe; font-size: 11px; vertical-alignment: center; width: 32px; }
            Slider {
                horizontal-stretch: 1;
                minimum: 0.0;
                maximum: 4.0;
                value: root.high-gain;
                released(v) => {
                    root.high-gain = v;
                    root.high-gain-changed(v);
                }
            }
        }

        // ── Display style ─────────────────────────────────────────────────────
        Text {
            text: "DISPLAY STYLE";
            color: #45475a;
            font-size: 10px;
        }

        ComboBox {
            model: ["Mirrored", "Top Half"];
            current-index: root.display-style;
            selected(v) => {
                root.display-style = self.current-index;
                root.display-style-changed(self.current-index);
            }
        }

        // ── Color scheme ──────────────────────────────────────────────────────
        Text {
            text: "COLOR SCHEME";
            color: #45475a;
            font-size: 10px;
        }

        ComboBox {
            model: ["Peach / Blue / Lavender", "Monochrome", "Per-Band Solid", "Grayscale"];
            current-index: root.color-scheme;
            selected(v) => {
                root.color-scheme = self.current-index;
                root.color-scheme-changed(self.current-index);
            }
        }

        // ── Normalization ─────────────────────────────────────────────────────
        CheckBox {
            text: "Normalize per track";
            checked: root.normalize;
            toggled => {
                root.normalize = self.checked;
                root.normalize-changed(self.checked);
            }
        }
    }
}
